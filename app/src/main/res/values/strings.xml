    <string name="privacy_policy_section_data_title">What the app stores</string>
    <string name="privacy_policy_section_data_body">Digital Wallet stores your categories, cards, reminder preferences, and Home search history locally on this device. This release does not include app-controlled cloud sync.</string>
    <string name="privacy_policy_section_permissions_title">Permissions and device access</string>
    <string name="privacy_policy_section_permissions_body">Notifications are used only for expiration reminders when you enable them. Card photo and scan flows use Android and Google ML Kit components only when you start them. Imported images, scanned codes, and typed card details are reviewed by you before saving.</string>
    <string name="privacy_policy_section_backup_title">Backup, restore, and export</string>
    <string name="privacy_policy_section_backup_body">Backup, restore, and export happen only when you explicitly choose a file and destination. Automatic Android cloud backup is disabled for this app so your data is not silently copied through system backup.</string>
    <string name="privacy_policy_section_retention_title">Data control</string>
    <string name="privacy_policy_section_retention_body">You control the wallet data stored in the app. You can edit or delete cards, clear Home search history, and remove app data from Android settings at any time.</string>
    <string name="terms_section_scope_title">App scope</string>
    <string name="terms_section_scope_body">Digital Wallet is for non-payment wallet items only, such as loyalty cards, memberships, tickets, access passes, and similar items. It is not intended for payment cards or payment transactions.</string>
    <string name="terms_section_responsibility_title">Your responsibility</string>
    <string name="terms_section_responsibility_body">You are responsible for the accuracy, legality, and appropriateness of the card content you add, import, scan, export, or back up with the app.</string>
    <string name="terms_section_backup_title">Local data handling</string>
    <string name="terms_section_backup_body">Backup, restore, and export files are created only when you request them and are stored in the locations you choose. Keep those files secure if they contain personal or membership information.</string>
    <string name="terms_section_availability_title">Availability</string>
    <string name="terms_section_availability_body">Some flows depend on device capabilities such as camera access, notification permission, file providers, or Google Play services components. Feature availability can vary by device configuration.</string>
